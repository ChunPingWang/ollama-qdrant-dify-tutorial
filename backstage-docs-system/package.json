{
  "name": "@backstage-docs/root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "18 || 20"
  },
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build": "backstage-cli repo build --all",
    "lint": "backstage-cli repo lint --since origin/main",
    "test": "jest --config jest.config.ts",
    "test:backend": "jest --config jest.config.ts --selectProjects backend",
    "test:plugins": "jest --config jest.config.ts --selectProjects plugin-docs-hub plugin-docs-module",
    "clean": "backstage-cli repo clean"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "^0.27.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.0",
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "typescript": "~5.3.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  }
}
